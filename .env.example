# =====================================================================
# 8130 APP — Environment Variables
# =====================================================================
# Copy this file to .env.local and fill in actual values.
# .env.local is git-ignored — NEVER commit it.
# =====================================================================

# ---------- Frontend (Vite — exposed to browser) ----------
# These values appear in the compiled bundle. Only put public values here.
# Vite requires the VITE_ prefix to expose vars to client code.

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---------- Backend / Edge Functions (server-side only) ----------
# These values must NEVER reach the browser bundle.
# Used by simulator, Edge Functions, migrations.

# Service-role key (full DB access, bypass RLS) — DO NOT EXPOSE
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook shared secret — value Base44 must send in `Authorization: Bearer <secret>`
WEBHOOK_SECRET=replace-with-random-string


# ---------- Database (only needed if running migrations from CLI) ----------
# Direct DB connection password (set when creating the Supabase project)
SUPABASE_DB_PASSWORD=your-db-password-here
